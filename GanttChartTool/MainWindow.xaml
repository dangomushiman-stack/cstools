<Window x:Class="GanttChartTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="650" Width="1300"
        x:Name="RootWindow" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="750"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <WrapPanel Grid.Row="0" Grid.ColumnSpan="3" Background="#F5F5F5" Orientation="Horizontal">
            <Button Content="＋ タスク" Width="70" Margin="5" Click="AddTask_Click" Background="White"/>
            <Button Content="📝 メモ" Width="60" Margin="5" Click="AddNote_Click" Background="White"/>
            <Border Width="1" Background="#DDDDDD" Margin="5,8"/>
            <Button Content="↑" Margin="2,5" Width="25" Click="MoveUp_Click" Background="White"/>
            <Button Content="↓" Margin="2,5" Width="25" Click="MoveDown_Click" Background="White"/>
            <Button Content="←" Margin="5,5,2,5" Width="25" Click="Outdent_Click" Background="White"/>
            <Button Content="→" Margin="2,5,5,5" Width="25" Click="Indent_Click" Background="White"/>
            <Border Width="1" Background="#DDDDDD" Margin="5,8"/>
            <Button Content="💾 保存" Margin="5" Padding="8,0" Click="Save_Click" Background="#E8F0FE" BorderBrush="SteelBlue"/>
            <Button Content="📂 読込" Margin="5" Padding="8,0" Click="Load_Click" Background="White"/>
            
            <Border Width="1" Background="#DDDDDD" Margin="5,8"/>
            <ToggleButton Content="🔗 矢印モード" IsChecked="{Binding IsLinkMode}" Margin="5" Padding="5,0"/>
            <ToggleButton Content="⏱ 時間モード" IsChecked="{Binding IsHourlyMode}" Margin="5" Padding="5,0"/>

            <Border Width="1" Background="#DDDDDD" Margin="5,8"/>
            <CheckBox Content="イナズマ線" IsChecked="{Binding IsProgressLineVisible}" VerticalAlignment="Center" Margin="5" FontSize="11"/>
            <CheckBox Content="営業日連動" IsChecked="{Binding IsWorkDayAdjustmentEnabled}" VerticalAlignment="Center" Margin="5" FontSize="11"/>

            <Border Width="1" Background="#DDDDDD" Margin="5,8"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="開始日:" VerticalAlignment="Center" Margin="5,0" FontSize="11" Foreground="Gray"/>
                <DatePicker SelectedDate="{Binding ProjectStartDate, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <TextBlock Text="表示数:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11" Foreground="Gray"/>
                <TextBox Text="{Binding DisplayDays, UpdateSourceTrigger=LostFocus}" Width="40" VerticalContentAlignment="Center" TextAlignment="Center"/>
            </StackPanel>
        </WrapPanel>

        <DataGrid x:Name="MainDataGrid" Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Tasks}" 
                  SelectedItem="{Binding DataGridSelectedTask}"
                  AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="40" ColumnHeaderHeight="40" 
                  VerticalContentAlignment="Center" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="↑ 上へ移動" Click="MoveUp_Click"/><MenuItem Header="↓ 下へ移動" Click="MoveDown_Click"/><Separator/><MenuItem Header="上に行を追加" Click="InsertAbove_Click"/><MenuItem Header="下に行を追加" Click="InsertBelow_Click"/><Separator/><MenuItem Header="行を削除" Click="DeleteRow_Click" Foreground="Red"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="30"/>
                
                <DataGridTemplateColumn Header="タスク名" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Margin="{Binding IndentMargin}" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="FontWeight" Value="Normal"/><Style.Triggers><DataTrigger Binding="{Binding IsGroup}" Value="True"><Setter Property="FontWeight" Value="Bold"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate><DataTemplate><TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="{Binding IndentMargin}"/></DataTemplate></DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="担当者" Binding="{Binding Assignee, UpdateSourceTrigger=PropertyChanged}" Width="60"/>

                <DataGridTemplateColumn Header="色" Width="55">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding DataContext.AvailableBarColors, RelativeSource={RelativeSource AncestorType=DataGrid}}" SelectedItem="{Binding BarColorName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                
                <DataGridTextColumn Header="%" Binding="{Binding Progress, UpdateSourceTrigger=PropertyChanged}" Width="35"/>
                <DataGridTextColumn Header="営業日" Binding="{Binding WorkDays, UpdateSourceTrigger=LostFocus}" Width="45"/>
                
                <DataGridTemplateColumn Header="開始" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Start, StringFormat=MM/dd}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding Start, StringFormat='MM/dd HH:mm'}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate><TextBox Text="{Binding Start, StringFormat=MM/dd, UpdateSourceTrigger=LostFocus}"><TextBox.Style><Style TargetType="TextBox"><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding Start, StringFormat='MM/dd HH:mm', UpdateSourceTrigger=LostFocus}"/></DataTrigger></Style.Triggers></Style></TextBox.Style></TextBox></DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="終了" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding End, StringFormat=MM/dd}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding End, StringFormat='MM/dd HH:mm'}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate><TextBox Text="{Binding End, StringFormat=MM/dd, UpdateSourceTrigger=LostFocus}"><TextBox.Style><Style TargetType="TextBox"><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding End, StringFormat='MM/dd HH:mm', UpdateSourceTrigger=LostFocus}"/></DataTrigger></Style.Triggers></Style></TextBox.Style></TextBox></DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="後作業名" Binding="{Binding SubTaskName, UpdateSourceTrigger=PropertyChanged}" Width="80"/>

                <DataGridTemplateColumn Header="後開始" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SubTaskStart, StringFormat=MM/dd, TargetNullValue=''}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding SubTaskStart, StringFormat='MM/dd HH:mm', TargetNullValue=''}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate><TextBox Text="{Binding SubTaskStart, StringFormat=MM/dd, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"><TextBox.Style><Style TargetType="TextBox"><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding SubTaskStart, StringFormat='MM/dd HH:mm', UpdateSourceTrigger=LostFocus, TargetNullValue=''}"/></DataTrigger></Style.Triggers></Style></TextBox.Style></TextBox></DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="後終了" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SubTaskEnd, StringFormat=MM/dd, TargetNullValue=''}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding SubTaskEnd, StringFormat='MM/dd HH:mm', TargetNullValue=''}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate><TextBox Text="{Binding SubTaskEnd, StringFormat=MM/dd, UpdateSourceTrigger=LostFocus, TargetNullValue=''}"><TextBox.Style><Style TargetType="TextBox"><Style.Triggers><DataTrigger Binding="{Binding DataContext.IsHourlyMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"><Setter Property="Text" Value="{Binding SubTaskEnd, StringFormat='MM/dd HH:mm', UpdateSourceTrigger=LostFocus, TargetNullValue=''}"/></DataTrigger></Style.Triggers></Style></TextBox.Style></TextBox></DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="後色" Width="55">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate><ComboBox ItemsSource="{Binding DataContext.AvailableBarColors, RelativeSource={RelativeSource AncestorType=DataGrid}}" SelectedItem="{Binding SubTaskBarColorName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/></DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="先行" Binding="{Binding PredecessorId, UpdateSourceTrigger=PropertyChanged}" Width="40"/>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

        <ScrollViewer x:Name="GanttScrollViewer" Grid.Row="1" Grid.Column="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#FAFAFA" ScrollChanged="GanttScrollViewer_ScrollChanged">
            <Grid HorizontalAlignment="Left" VerticalAlignment="Top" MouseLeftButtonDown="ChartBackground_MouseLeftButtonDown">
                <ItemsControl ItemsSource="{Binding GridDays}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="{Binding Left}"/></Style></ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate><DataTemplate><Border Width="40" Background="{Binding BackgroundColor}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}"/></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" IsHitTestVisible="False">
                    <Rectangle Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="40" Fill="LightYellow" Opacity="0.8" Canvas.Top="{Binding DataGridSelectedTask.RowTop}">
                        <Rectangle.Style><Style TargetType="Rectangle"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding DataGridSelectedTask}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Rectangle.Style>
                    </Rectangle>
                </Canvas>

                <ItemsControl ItemsSource="{Binding GridDays}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" IsHitTestVisible="False"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="{Binding Left}"/></Style></ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate><DataTemplate><Grid Width="40"><Rectangle Width="1" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" Fill="#DDDDDD" HorizontalAlignment="Left"/><Border Height="40" VerticalAlignment="Top" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1"><TextBlock Text="{Binding DayText}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></Grid></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding DependencyLines}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" IsHitTestVisible="False"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate><DataTemplate><Path Stroke="{Binding LineBrush}" StrokeThickness="2" Data="{Binding PathData}"/></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <ItemsControl ItemsSource="{Binding Tasks}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="0"/><Setter Property="Canvas.Top" Value="0"/></Style></ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Canvas>
                                <Border Canvas.Left="{Binding GhostLeft}" Canvas.Top="{Binding Top}" Width="{Binding GhostWidth}" Height="{Binding BarHeight}" Background="{Binding BarColor}" Opacity="0.3" CornerRadius="2">
                                    <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsDragging}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                </Border>
                                
                                <Border Canvas.Left="{Binding Left}" Canvas.Top="{Binding Top}" Width="{Binding Width}" Height="{Binding BarHeight}" Background="{Binding BarColor}" Opacity="{Binding BarOpacity}" CornerRadius="2" Cursor="SizeAll" ClipToBounds="True" MouseLeftButtonDown="TaskBar_MouseLeftButtonDown" MouseMove="TaskBar_MouseMove" MouseLeftButtonUp="TaskBar_MouseLeftButtonUp">
                                    <Border.Effect><DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.2"/></Border.Effect>
                                    <Grid>
                                        <Rectangle Fill="#50000000" Width="{Binding ProgressWidth}" HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="11" IsHitTestVisible="False">
                                            <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsGroup}" Value="True"><Setter Property="Visibility" Value="Hidden"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                        </TextBlock>
                                        <Border Width="8" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="TaskBarResizeLeft_MouseLeftButtonDown" MouseMove="TaskBar_MouseMove" MouseLeftButtonUp="TaskBar_MouseLeftButtonUp"/>
                                        <Border Width="8" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="TaskBarResizeRight_MouseLeftButtonDown" MouseMove="TaskBar_MouseMove" MouseLeftButtonUp="TaskBar_MouseLeftButtonUp"/>
                                    </Grid>
                                </Border>

                                <Border Canvas.Left="{Binding SubTaskLeft}" Canvas.Top="{Binding Top}" Width="{Binding SubTaskWidth}" Height="{Binding BarHeight}" Background="{Binding SubTaskBarColor}" Visibility="{Binding SubTaskVisibility}" Opacity="0.8" CornerRadius="2" BorderBrush="White" BorderThickness="1,0,1,0" Cursor="SizeAll" ClipToBounds="True" MouseLeftButtonDown="SubTaskBar_MouseLeftButtonDown" MouseMove="SubTaskBar_MouseMove" MouseLeftButtonUp="SubTaskBar_MouseLeftButtonUp">
                                    <Border.Style><Style TargetType="Border"><Style.Triggers><DataTrigger Binding="{Binding IsGroup}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                    <Grid>
                                        <TextBlock Text="{Binding SubTaskName}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Normal" Opacity="0.9" IsHitTestVisible="False"/>
                                        <Border Width="8" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="SubTaskBarResizeLeft_MouseLeftButtonDown" MouseMove="SubTaskBar_MouseMove" MouseLeftButtonUp="SubTaskBar_MouseLeftButtonUp"/>
                                        <Border Width="8" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWE" MouseLeftButtonDown="SubTaskBarResizeRight_MouseLeftButtonDown" MouseMove="SubTaskBar_MouseMove" MouseLeftButtonUp="SubTaskBar_MouseLeftButtonUp"/>
                                    </Grid>
                                </Border>
                            </Canvas>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" IsHitTestVisible="False">
                    <Rectangle Canvas.Left="{Binding TodayLeft}" Width="1" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}" Fill="Red" Opacity="0.5"/>
                    <Path Stroke="Red" StrokeThickness="1.2" StrokeLineJoin="Round" Data="{Binding ProgressLinePath}" Opacity="0.9">
                        <Path.Style><Style TargetType="Path"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsProgressLineVisible}" Value="False"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Path.Style>
                        <Path.Effect><DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="Red" Opacity="0.4"/></Path.Effect>
                    </Path>
                </Canvas>
                
                <ItemsControl ItemsSource="{Binding Notes}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Width="{Binding DataContext.ChartWidth, ElementName=RootWindow}" Height="{Binding DataContext.ChartHeight, ElementName=RootWindow}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle><Style TargetType="ContentPresenter"><Setter Property="Canvas.Left" Value="{Binding X}"/><Setter Property="Canvas.Top" Value="{Binding Y}"/></Style></ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate><DataTemplate><Border Width="{Binding Width}" Height="{Binding Height}" Background="#FFFFE0" BorderBrush="#E0E080" BorderThickness="1" CornerRadius="3"><Border.Effect><DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.2"/></Border.Effect><Grid><TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent" BorderThickness="0" Padding="5,15,5,10" FontSize="12"/><Border Height="15" VerticalAlignment="Top" Background="#10000000" Cursor="SizeAll" MouseLeftButtonDown="Note_MouseLeftButtonDown" MouseMove="Note_MouseMove" MouseLeftButtonUp="Note_MouseLeftButtonUp"><Border.ContextMenu><ContextMenu><MenuItem Header="削除" Click="DeleteNote_Click"/></ContextMenu></Border.ContextMenu></Border><Border Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseLeftButtonDown="NoteResize_MouseLeftButtonDown" MouseMove="NoteResize_MouseMove" MouseLeftButtonUp="NoteResize_MouseLeftButtonUp"><Path Data="M 12,0 L 12,12 L 0,12 Z" Fill="#40000000" IsHitTestVisible="False"/></Border></Grid></Border></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" Width="280" Background="#FFFFFF" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0">
            <Border.Style><Style TargetType="Border"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding MemoTask}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Border.Style>
            <Border.Effect><DropShadowEffect BlurRadius="10" ShadowDepth="-2" Opacity="0.1"/></Border.Effect>
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Background="#F5F5F5" Padding="10"><TextBlock Text="{Binding MemoTask.Name, StringFormat='📝 {0}'}" FontWeight="Bold" Foreground="#333333" FontSize="14" TextTrimming="CharacterEllipsis"/></Border>
                <TextBox Grid.Row="1" Text="{Binding MemoTask.Memo, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="White" BorderThickness="0" Padding="12" FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>